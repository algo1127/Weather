<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <com.algo1127.weather.SkyBackgroundView
        android:id="@+id/skyBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />


    <!-- Loading Spinner -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#FFFFFF" />

    <!-- Error Message -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone"
        tools:text="Error al cargar el clima" />

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="40dp">

            <!-- 1. Header: Location & Refresh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvCityName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="18sp"
                        app:autoSizeMaxTextSize="28sp"
                        tools:text="Madrid" />
                    <TextView
                        android:id="@+id/tvProvince"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E0E7FF"
                        android:textSize="14sp"
                        android:alpha="0.8"
                        tools:text="Comunidad de Madrid" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnRefresh"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Actualizar"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@android:color/transparent"
                    android:background="@drawable/pill_frosted_bg"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:foreground="?attr/selectableItemBackground" />
            </LinearLayout>

            <!-- 2. Hero Section: Immersive Current Weather -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottieHeroIcon"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_speed="1.0" />

                <TextView
                    android:id="@+id/tvTemperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="96sp"
                    android:fontFamily="sans-serif-thin"
                    android:layout_marginTop="-16dp"
                    tools:text="33°" />

                <TextView
                    android:id="@+id/tvSkyCondition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="Poco nuboso" />

                <TextView
                    android:id="@+id/tvTempRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E0E7FF"
                    android:textSize="16sp"
                    android:alpha="0.9"
                    android:layout_marginTop="4dp"
                    tools:text="Min 19°  •  Max 33°" />

                <TextView
                    android:id="@+id/tvFeelsLike"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E0E7FF"
                    android:textSize="14sp"
                    android:alpha="0.8"
                    android:layout_marginTop="4dp"
                    tools:text="Sensación térmica: 35°" />
            </LinearLayout>

            <!-- 3. The Hidden Gem: Hourly Forecast -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRONÓSTICO POR HORAS"
                android:textColor="#E0E7FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:alpha="0.8"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHourlyForecast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:layout_marginBottom="32dp" />

            <!-- 4. Detailed Stats Grid (Apple-Style Widget Cards) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Humidity Card (WITH HUMIDITY ICON) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/weather_card_bg"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp"
                    android:elevation="4dp"
                    android:gravity="center_vertical">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieHumidityIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HUMEDAD"
                        android:textColor="#E0E7FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:alpha="0.8"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:id="@+id/tvHumidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="12sp"
                        app:autoSizeMaxTextSize="24sp"
                        tools:text="20% - 40%" />
                </LinearLayout>

                <!-- Wind Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/weather_card_bg"
                    android:padding="16dp"
                    android:layout_marginStart="6dp"
                    android:elevation="4dp"
                    android:gravity="center_vertical">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieWindIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIENTO"
                        android:textColor="#E0E7FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:alpha="0.8"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:id="@+id/tvWind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="12sp"
                        app:autoSizeMaxTextSize="20sp"
                        tools:text="SE 10 km/h" />
                    <TextView
                        android:id="@+id/tvWindGust"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E0E7FF"
                        android:textSize="11sp"
                        android:alpha="0.7"
                        tools:text="Rachas: 25 km/h" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <!-- UV Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/weather_card_bg"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp"
                    android:elevation="4dp"
                    android:gravity="center_vertical">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieUvIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ÍNDICE UV"
                        android:textColor="#E0E7FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:alpha="0.8"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:id="@+id/tvUV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="12sp"
                        app:autoSizeMaxTextSize="24sp"
                        tools:text="9 (Muy Alto)" />
                </LinearLayout>

                <!-- Rain Card (WITH RAIN ICON) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/weather_card_bg"
                    android:padding="16dp"
                    android:layout_marginStart="6dp"
                    android:elevation="4dp"
                    android:gravity="center_vertical">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieRainIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PROB. LLUVIA"
                        android:textColor="#E0E7FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:alpha="0.8"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:id="@+id/tvRain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="12sp"
                        app:autoSizeMaxTextSize="24sp"
                        tools:text="0%" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Sunrise Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/weather_card_bg"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp"
                    android:elevation="4dp"
                    android:gravity="center_vertical">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieSunriseIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMANECER"
                        android:textColor="#E0E7FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:alpha="0.8"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:id="@+id/tvSunrise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        tools:text="06:45" />
                </LinearLayout>

                <!-- Sunset Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/weather_card_bg"
                    android:padding="16dp"
                    android:layout_marginStart="6dp"
                    android:elevation="4dp"
                    android:gravity="center_vertical">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieSunsetIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ATARDECER"
                        android:textColor="#E0E7FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:alpha="0.8"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:id="@+id/tvSunset"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        tools:text="21:30" />
                </LinearLayout>
            </LinearLayout>

            <!-- 5. 7-Day Forecast -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRONÓSTICO DE 7 DÍAS"
                android:textColor="#E0E7FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:alpha="0.8"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDailyForecast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:layout_marginBottom="24dp" />

            <!-- 6. Legal Footer -->
            <com.algo1127.weather.ui.StrokeTextView
                android:id="@+id/tvLegalFooter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                tools:text="Actualizado: 12/06 14:01 | © AEMET" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>